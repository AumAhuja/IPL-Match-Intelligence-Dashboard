    "---\n",
    "## 3. Team Performance Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate team wins\n",
    "team_wins = matches['match_winner'].value_counts().sort_values(ascending=False)\n",
    "team_matches = pd.concat([matches['team1'], matches['team2']]).value_counts()\n",
    "\n",
    "team_performance = pd.DataFrame({\n",
    "    'Matches': team_matches,\n",
    "    'Wins': team_wins\n",
    "}).fillna(0).astype(int)\n",
    "\n",
    "team_performance['Win %'] = (team_performance['Wins'] / team_performance['Matches'] * 100).round(1)\n",
    "team_performance = team_performance.sort_values('Wins', ascending=False)\n",
    "\n",
    "print(\"=\"*80)\n",
    "print(\"TEAM PERFORMANCE STATISTICS\")\n",
    "print(\"=\"*80)\n",
    "print(\"\\n\" + team_performance.to_string())\n",
    "\n",
    "# Visualization\n",
    "fig, ax = plt.subplots(figsize=(14, 6))\n",
    "\n",
    "x = np.arange(len(team_performance))\n",
    "width = 0.35\n",
    "\n",
    "ax.bar(x - width/2, team_performance['Wins'], width, label='Wins', color='#2ecc71', alpha=0.8)\n",
    "ax.bar(x + width/2, team_performance['Matches'] - team_performance['Wins'], \n",
    "       width, label='Losses', color='#e74c3c', alpha=0.8)\n",
    "\n",
    "ax.set_xlabel('Team', fontweight='bold')\n",
    "ax.set_ylabel('Number of Matches', fontweight='bold')\n",
    "ax.set_title('Team Win-Loss Record (IPL 2026 - Up to Match 51)', fontsize=14, fontweight='bold')\n",
    "ax.set_xticks(x)\n",
    "ax.set_xticklabels(team_performance.index, rotation=45, ha='right')\n",
    "ax.legend()\n",
    "ax.grid(axis='y', alpha=0.3)\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../visualizations/team_performance.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✓ Visualization saved: team_performance.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
