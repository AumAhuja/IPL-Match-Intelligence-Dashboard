    "# Bowling analysis\n",
    "bowling_df = deliveries.copy()\n",
    "\n",
    "bowling_df['is_dot'] = (bowling_df['total_runs'] == 0).astype(int)\n",
    "bowling_df['is_wicket'] = bowling_df['player_dismissed'].notnull().astype(int)\n",
    "bowling_df.loc[bowling_df['wicket_type'] == 'run out', 'is_wicket'] = 0\n",
    "\n",
    "bowler_stats = bowling_df.groupby('bowler').agg({\n",
    "    'total_runs': 'sum',\n",
    "    'is_dot': 'sum',\n",
    "    'is_wicket': 'sum'\n",
    "}).rename(columns={'is_wicket': 'wickets', 'is_dot': 'dots'})\n",
    "\n",
    "bowler_stats['balls'] = bowling_df.groupby('bowler').size()\n",
    "bowler_stats['overs'] = bowler_stats['balls'] / 6\n",
    "bowler_stats['economy'] = bowler_stats['total_runs'] / bowler_stats['overs']\n",
    "bowler_stats['dot_pct'] = (bowler_stats['dots'] / bowler_stats['balls']) * 100\n",
    "\n",
    "# Filter minimum 60 balls\n",
    "bowler_stats = bowler_stats[bowler_stats['balls'] >= 60].sort_values('economy')\n",
    "\n",
    "print(\"=\"*80)\n",
    "print(\"BOWLING ANALYSIS\")\n",
    "print(\"=\"*80)\n",
