    "print(\"\\nTop 10 Death Over Run Scorers (Overs 16-20):\")\n",
    "for i, (player, runs) in enumerate(death_runs.items(), 1):\n",
    "    print(f\"{i:2d}. {player:25s} - {runs:4.0f} runs\")\n",
    "\n",
    "# Visualization\n",
    "fig, ax = plt.subplots(figsize=(12, 7))\n",
    "death_runs.plot(kind='barh', ax=ax, color='#9b59b6', edgecolor='purple', linewidth=1.5)\n",
    "ax.set_xlabel('Runs', fontweight='bold', fontsize=12)\n",
    "ax.set_title('Death Over Specialists - Top Run Scorers (IPL 2026)', fontsize=14, fontweight='bold')\n",
    "ax.grid(axis='x', alpha=0.3)\n",
    "\n",
    "for i, v in enumerate(death_runs.values):\n",
    "    ax.text(v + 3, i, str(int(v)), va='center', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../visualizations/death_over_specialists.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✓ Visualization saved: death_over_specialists.png\")"
   ]
