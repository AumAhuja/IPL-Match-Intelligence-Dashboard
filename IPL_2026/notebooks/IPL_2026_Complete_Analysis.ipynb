    "---\n",
    "## 5. Batting Analysis: The Hit-Makers"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Prepare deliveries data\n",
    "deliveries['is_boundary'] = deliveries['runs_of_bat'].isin([4, 6]).astype(int)\n",
    "deliveries['is_out'] = deliveries['player_dismissed'].notnull().astype(int)\n",
    "deliveries['total_runs'] = deliveries['runs_of_bat'] + deliveries['extras']\n",
    "\n",
    "print(\"=\"*80)\n",
    "print(\"BATTING ANALYSIS\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "# Top run scorers\n",
    "top_scorers = deliveries.groupby('striker')['runs_of_bat'].sum().sort_values(ascending=False).head(10)\n",
    "\n",
    "print(\"\\nTop 10 Run Scorers (Runs off Bat):\")\n",
    "for i, (player, runs) in enumerate(top_scorers.items(), 1):\n",
    "    print(f\"{i:2d}. {player:25s} - {runs:4.0f} runs\")\n",
    "\n",
    "# Visualization\n",
    "fig, ax = plt.subplots(figsize=(12, 7))\n",
    "top_scorers.plot(kind='barh', ax=ax, color='#3498db', edgecolor='navy', linewidth=1.5)\n",
    "ax.set_xlabel('Runs', fontweight='bold', fontsize=12)\n",
    "ax.set_title('Top 10 Run Scorers in IPL 2026 (Up to Match 51)', fontsize=14, fontweight='bold')\n",
    "ax.grid(axis='x', alpha=0.3)\n",
    "\n",
    "# Add value labels\n",
    "for i, v in enumerate(top_scorers.values):\n",
    "    ax.text(v + 10, i, str(int(v)), va='center', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../visualizations/top_run_scorers.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✓ Visualization saved: top_run_scorers.png\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Boundary hitters\n",
    "boundaries = deliveries.groupby('striker')['is_boundary'].sum().sort_values(ascending=False).head(10)\n",
    "\n",
    "print(\"\\nTop 10 Boundary Hitters (Fours + Sixes):\")\n",
    "for i, (player, count) in enumerate(boundaries.items(), 1):\n",
    "    print(f\"{i:2d}. {player:25s} - {count:3.0f} boundaries\")\n",
    "\n",
    "# Visualization\n",
    "fig, ax = plt.subplots(figsize=(12, 7))\n",
    "boundaries.plot(kind='barh', ax=ax, color='#e74c3c', edgecolor='darkred', linewidth=1.5)\n",
    "ax.set_xlabel('Number of Boundaries (4s & 6s)', fontweight='bold', fontsize=12)\n",
    "ax.set_title('Top Boundary Hitters in IPL 2026', fontsize=14, fontweight='bold')\n",
    "ax.grid(axis='x', alpha=0.3)\n",
    "\n",
    "for i, v in enumerate(boundaries.values):\n",
    "    ax.text(v + 0.5, i, str(int(v)), va='center', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../visualizations/top_boundary_hitters.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✓ Visualization saved: top_boundary_hitters.png\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Strike rate analysis (minimum 50 balls)\n",
    "batter_stats = deliveries.groupby('striker').agg({\n",
    "    'runs_of_bat': 'sum',\n",
    "    'over': 'count',\n",
    "    'is_boundary': 'sum',\n",
    "    'is_out': 'sum'\n",
    }).rename(columns={'over': 'balls_faced'})\n",
    "\n",
    "batter_stats['strike_rate'] = (batter_stats['runs_of_bat'] / batter_stats['balls_faced']) * 100\n",
    "batter_stats = batter_stats[batter_stats['balls_faced'] >= 50]\n",
    "batter_stats['avg'] = batter_stats['runs_of_bat'] / batter_stats['is_out'].replace(0, 1)\n",
    "\n",
    "top_sr = batter_stats['strike_rate'].sort_values(ascending=False).head(10)\n",
    "\n",
    "print(\"\\nTop 10 Batters by Strike Rate (Min 50 balls):\")\n",
    "for i, (player, sr) in enumerate(top_sr.items(), 1):\n",
    "    balls = int(batter_stats.loc[player, 'balls_faced'])\n",
    "    runs = int(batter_stats.loc[player, 'runs_of_bat'])\n",
    "    print(f\"{i:2d}. {player:25s} - SR: {sr:6.2f} (Runs: {runs}, Balls: {balls})\")\n",
    "\n",
    "# Visualization\n",
    "fig, ax = plt.subplots(figsize=(12, 7))\n",
    "top_sr.plot(kind='barh', ax=ax, color='#f39c12', edgecolor='darkorange', linewidth=1.5)\n",
    "ax.set_xlabel('Strike Rate', fontweight='bold', fontsize=12)\n",
    "ax.set_title('Top 10 Batters by Strike Rate (IPL 2026)', fontsize=14, fontweight='bold')\n",
    "ax.grid(axis='x', alpha=0.3)\n",
    "\n",
    "for i, v in enumerate(top_sr.values):\n",
    "    ax.text(v + 1, i, f\"{v:.1f}\", va='center', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../visualizations/top_strike_rates.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✓ Visualization saved: top_strike_rates.png\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Story: The Art and Science of Batting\n",
    "\n",
    "IPL 2026's batting landscape reveals three distinct player archetypes:\n",
    "\n",
    "**The Accumulator**: Players with the highest run totals who have built their reputation through consistency and longevity in the middle order. These players provide stability and backbone to their teams.\n",
    "\n",
    "**The Explosive Threat**: Boundary hitters who change the momentum of the game with aggressive shot-making. Their presence in the crease forces bowling teams to rethink their strategies.\n",
    "\n",
    "**The Strikeware**: Players with exceptional strike rates who maximize every opportunity. They understand T20 dynamics perfectly - rotating strike and punishing loose balls.\n",
    "\n",
    "The interplay of these player types in a batting lineup often determines match outcomes. Teams that balance aggressive and stable batting approaches tend to be more successful across varying match situations."
   ]
  },
