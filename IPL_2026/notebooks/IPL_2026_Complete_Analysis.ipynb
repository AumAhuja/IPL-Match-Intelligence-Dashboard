    "---\n",
    "## 9. Player Impact Score (Composite Performance Metric)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Calculate impact scores\n",
    "print(\"=\"*80)\n",
    "print(\"PLAYER IMPACT SCORE ANALYSIS\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "# Recalculate batter stats for impact score\n",
    "impact_stats = deliveries.groupby('striker').agg({\n",
    "    'runs_of_bat': 'sum',\n",
    "    'is_boundary': 'sum',\n",
    "    'is_out': 'sum'\n",
    "}).rename(columns={'is_boundary': 'boundaries', 'is_out': 'dismissals'})\n",
    "\n",
    "impact_stats['balls_faced'] = deliveries.groupby('striker').size()\n",
    "impact_stats = impact_stats[impact_stats['balls_faced'] >= 60]  # Minimum qualification\n",
    "\n",
    "impact_stats['strike_rate'] = (impact_stats['runs_of_bat'] / impact_stats['balls_faced']) * 100\n",
    "impact_stats['average'] = impact_stats['runs_of_bat'] / impact_stats['dismissals'].replace(0, 1)\n",
    "impact_stats['boundary_pct'] = (impact_stats['boundaries'] / impact_stats['balls_faced']) * 100\n",
    "\n",
    "# Impact score formula: 40% SR + 30% Average + 30% Boundary%\n",
    "impact_stats['impact_score'] = (\n",
    "    0.4 * impact_stats['strike_rate'] + \n",
    "    0.3 * impact_stats['average'] + \n",
    "    0.3 * impact_stats['boundary_pct']\n)\n",
    "\n",
    "top_impact = impact_stats.sort_values('impact_score', ascending=False).head(15)\n",
    "\n",
    "print(\"\\nTop 15 Players by Impact Score (Min 60 balls):\")\n",
    "print(\"\\nMetric: 40% Strike Rate + 30% Average + 30% Boundary %\\n\")\n",
    "for i, (player, row) in enumerate(top_impact.iterrows(), 1):\n",
    "    print(f\"{i:2d}. {player:25s} - Impact: {row['impact_score']:6.2f}\")\n",
    "    print(f\"    {'':25s}   (SR: {row['strike_rate']:5.1f}, Avg: {row['average']:6.1f}, Boundary%: {row['boundary_pct']:5.1f})\")\n",
    "\n",
    "# Visualization\n",
    "fig, ax = plt.subplots(figsize=(12, 8))\n",
    "top_impact_sorted = top_impact.sort_values('impact_score', ascending=True)\n",
    "colors_impact = plt.cm.RdYlGn(np.linspace(0.3, 0.9, len(top_impact_sorted)))\n",
    "\n",
    "top_impact_sorted['impact_score'].plot(kind='barh', ax=ax, color=colors_impact, edgecolor='black', linewidth=1.5)\n",
    "ax.set_xlabel('Impact Score', fontweight='bold', fontsize=12)\n",
    "ax.set_title('Top Players by Composite Impact Score (IPL 2026)', fontsize=14, fontweight='bold')\n",
    "ax.grid(axis='x', alpha=0.3)\n",
    "\n",
    "for i, v in enumerate(top_impact_sorted['impact_score'].values):\n",
    "    ax.text(v + 0.2, i, f\"{v:.2f}\", va='center', fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../visualizations/impact_scores.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✓ Visualization saved: impact_scores.png\")"
   ]
  },
