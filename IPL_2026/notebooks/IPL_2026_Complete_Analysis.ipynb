   "source": [
    "---\n",
    "## 2. Match-Level Analysis"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Basic match statistics\n",
    "print(\"=\"*80)\n",
    "print(\"MATCH STATISTICS\")\n",
    "print(\"=\"*80)\n",
    "\n",
    "# Convert date to datetime\n",
    "matches['date'] = pd.to_datetime(matches['date'])\n",
    "deliveries['date'] = pd.to_datetime(deliveries['date'])\n",
    "\n",
    "# Calculate match statistics\n",
    "print(f\"\\nTotal Matches Analyzed: {len(matches)}\")\n",
    "print(f\"Season Duration: {matches['date'].min().date()} to {matches['date'].max().date()}\")\n",
    "print(f\"Duration: {(matches['date'].max() - matches['date'].min()).days} days\")\n",
    "\n",
    "# Win statistics\n",
    "total_matches = len(matches)\n",
    "wins_by_result = matches['match_result'].value_counts()\n",
    "print(f\"\\nMatch Results:\")\n",
    "for result, count in wins_by_result.items():\n",
    "    print(f\"  {result.capitalize()}: {count} matches ({count/total_matches*100:.1f}%)\")\n",
    "\n",
    "# Teams analysis\n",
    "all_teams = pd.concat([matches['team1'], matches['team2']]).unique()\n",
    "print(f\"\\nTotal Teams: {len(all_teams)}\")\n",
    "print(f\"Teams: {', '.join(sorted(all_teams))}\")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Venue analysis\n",
    "venue_stats = matches['venue'].value_counts()\n",
    "print(f\"\\nMatches by Venue:\")\n",
    "print(venue_stats)\n",
    "print(f\"\\nTotal Unique Venues: {len(venue_stats)}\")\n",
    "\n",
    "# Create visualization\n",
    "fig, ax = plt.subplots(1, 2, figsize=(15, 6))\n",
    "\n",
    "# Venues\n",
    "venue_stats.plot(kind='barh', ax=ax[0], color='steelblue')\n",
    "ax[0].set_title('Matches Hosted by Each Venue', fontsize=14, fontweight='bold')\n",
    "ax[0].set_xlabel('Number of Matches')\n",
    "ax[0].grid(axis='x', alpha=0.3)\n",
    "\n",
    "# Match results\n",
    "result_stats = matches['match_result'].value_counts()\n",
    "colors = ['#2ecc71', '#e74c3c', '#f39c12']\n",
    "ax[1].pie(result_stats.values, labels=result_stats.index, autopct='%1.1f%%', \n",
    "         colors=colors, startangle=90)\n",
    "ax[1].set_title('Distribution of Match Results', fontsize=14, fontweight='bold')\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.savefig('../visualizations/match_overview.png', dpi=300, bbox_inches='tight')\n",
    "plt.show()\n",
    "\n",
    "print(\"\\n✓ Visualization saved: match_overview.png\")"
   ]
